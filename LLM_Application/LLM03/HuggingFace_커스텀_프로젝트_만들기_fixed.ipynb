        "    # 배치가 클수록 한 스텝에 더 많은 샘플을 처리 → 학습 시간 단축\n",
        "    # 단, 너무 크면 수렴이 불안정해질 수 있음 (여기서는 64가 적절)\n",
        "    # --------------------------------------------------------\n",
        "    per_device_train_batch_size=64,\n",
        "\n",
        "    # 평가 시 배치 크기는 더 크게 잡아도 메모리 문제 없음 (역전파 없음)\n",
        "    per_device_eval_batch_size=128,\n",
        "\n",
        "    # --------------------------------------------------------\n",
